          'value="'+paid+'" onchange="updPaid(\''+cid+'\','+mo+',\''+m.id+'\',this.value)"></td>'+
        '<td>'+(pend>0?'<span class="b br">'+R(pend)+'</span>'+(intA>0?'<br><span style="font-size:9px;color:var(--orange)">+'+R(intA)+' int</span>':''):'<span class="b bg">✓</span>')+'</td>'+
        '<td>'+(pend>0?'<button class="btn btn-o btn-sm" onclick="applyInt(\''+cid+'\','+mo+',\''+m.id+'\','+pend+')">+3%</button>':'')+'</td></tr>';
    }).join('')+'</tbody></table></div>';
}

function updPaid(cid,mo,mid,val){
  var key=mkey(cid,mo,mid);
  var old=D.mpay[key]||0;
  var nv=parseFloat(val)||0;
  D.mpay[key]=nv;
  var m=D.members.find(function(x){ return x.id===mid; });
  if(m) m.totalPaid=m.totalPaid-old+nv;
  toast('✅ Payment updated');
}

function applyInt(cid,mo,mid,pend){
  if(pend<=0){ toast('No pending'); return; }
  var intA=Math.round(pend*0.03);
  var k='I_'+cid+'_'+mo+'_'+mid;
  D.interest[k]=(D.interest[k]||0)+intA;
  var m=D.members.find(function(x){ return x.id===mid; });
  toast('⚠ 3% interest '+R(intA)+' applied — '+(m?m.name:'member'));
  renderSlip();
}

