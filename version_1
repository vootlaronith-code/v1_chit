// ── MEMBERS ──
function addMember(){
  var n=document.getElementById('mb-n').value.trim();
  var ph=document.getElementById('mb-ph').value.trim();
  var ch=document.getElementById('mb-ch').value;
  var du=parseFloat(document.getElementById('mb-du').value);
  var ag=document.getElementById('mb-ag').value;
  var rf=document.getElementById('mb-rf').value;
  if(!n||!ph||!ch||!du){ toast('⚠ Fill Name, Phone, Chit, Due'); return; }
  if(D.members.find(function(m){ return m.phone===ph&&m.chitId===ch; })){ toast('⚠ Phone already in this chit'); return; }
  D.members.push({id:nid(),chitId:ch,name:n,phone:ph,due:du,agentId:ag,refId:rf,totalPaid:0,liftedMonth:null});
  document.getElementById('mb-n').value='';
  document.getElementById('mb-ph').value='';
  document.getElementById('mb-du').value='';
  renderMembers(); renderChitTypes(); renderAccounts();
  toast('✅ Member added!');
}

function renderMembers(){
  var el=document.getElementById('members-list'); if(!el) return;
  var q=(document.getElementById('mb-srch')||{value:''}).value.toLowerCase();
  var list=D.members.filter(function(m){ return !q||m.name.toLowerCase().includes(q)||m.phone.includes(q); });
  if(!list.length){ el.innerHTML='<div class="emp"><div class="emp-i">👥</div><div class="emp-t">No members found.</div></div>'; return; }
  el.innerHTML='<div class="card"><table class="tbl"><thead><tr><th>Name</th><th>Phone</th><th>Chit</th><th>Due</th><th>Agent</th><th>Status</th></tr></thead><tbody>'+
    list.map(function(m){
      var c=getCT(m.chitId); var a=getAg(m.agentId);
      return '<tr><td><strong>'+m.name+'</strong></td><td>'+m.phone+'</td><td>'+(c?c.name:'—')+'</td><td>'+R(m.due)+'</td><td>'+(a?a.name:'—')+'</td>'+
        '<td>'+(isLifted(m)?'<span class="b bgo">🏆 M'+m.liftedMonth+'</span>':'<span class="b bg">Active</span>')+'</td></tr>';
    }).join('')+'</tbody></table></div>';
}

// ── SLABS ──
function addSlab(){
  var ch=document.getElementById('sl-ch').value;
  var mo=parseInt(document.getElementById('sl-mo').value);
  var dv=parseFloat(document.getElementById('sl-dv').value);
  var cm=parseFloat(document.getElementById('sl-cm').value)||0;
  if(!ch||!mo||!dv){ toast('⚠ Fill Chit, Month, Dividend'); return; }
  D.slabs=D.slabs.filter(function(s){ return !(s.chitId===ch&&s.month===mo); });
  D.slabs.push({chitId:ch,month:mo,dividend:dv,comm:cm});
  document.getElementById('sl-mo').value='';
  document.getElementById('sl-dv').value='';
  document.getElementById('sl-cm').value='';
  renderSlabs();
  toast('✅ Slab saved!');
}

function renderSlabs(){
  var el=document.getElementById('slabs-list'); if(!el) return;
  el.innerHTML='';
  D.chitTypes.forEach(function(ct){
    var slabs=D.slabs.filter(function(s){ return s.chitId===ct.id; }).sort(function(a,b){ return a.month-b.month; });
    if(!slabs.length) return;
    el.innerHTML+='<div class="card"><div class="ct">'+ct.name+'</div>'+
      '<div class="slr" style="font-weight:700"><span>Month</span><span>Dividend</span><span>Commission</span></div>'+
      slabs.map(function(s){ return '<div class="slr"><span>Month '+s.month+'</span><span>'+R(s.dividend)+'</span><span>'+R(s.comm)+'</span></div>'; }).join('')+'</div>';
  });
  if(!el.innerHTML) el.innerHTML='<div class="emp"><div class="emp-i">📊</div><div class="emp-t">No slabs defined.</div></div>';
}

// ── ACCOUNTS ──
function renderAccounts(){
  var el=document.getElementById('cm-acc-body'); if(!el) return;
  if(!D.chitTypes.length){ el.innerHTML='<div class="emp"><div class="emp-i">📁</div><div class="emp-t">No chit types yet.</div></div>'; return; }
  el.innerHTML=D.chitTypes.map(function(ct){
    var mbs=D.members.filter(function(m){ return m.chitId===ct.id; });
    var coll=mbs.reduce(function(s,m){ return s+m.totalPaid; },0);
    var lifted=mbs.filter(function(m){ return isLifted(m); }).length;
    return '<div class="card"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">'+
      '<div><div style="font-family:Playfair Display,serif;font-size:15px;font-weight:700">'+ct.name+'</div>'+
      '<div style="font-size:11px;color:var(--ink3)">'+R(ct.value)+' &bull; '+ct.months+' months</div></div>'+
      '<span class="b '+(ct.status==='Running'?'bg':'bgy')+'">'+ct.status+'</span></div>'+
