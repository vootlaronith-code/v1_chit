        '<div class="mc-g">'+
        '<div class="mc-gi"><div class="mc-gl">Principal</div><div class="mc-gv r">'+R(l.amount)+'</div></div>'+
        '<div class="mc-gi"><div class="mc-gl">Monthly Int</div><div class="mc-gv o">'+R(mInt)+'</div></div>'+
        '<div class="mc-gi"><div class="mc-gl">Total Due</div><div class="mc-gv r">'+R(total)+'</div></div></div>'+
        '<div style="font-size:11px;color:var(--ink3);margin-top:4px">📅 Date: '+(l.date||'—')+' &bull; '+l.months+' months &bull; Ref: '+(getAg(l.refId)||{name:'—'}).name+'</div></div>';
    }).join('');
  }
}

function agCollect(mid){
  var inp=document.getElementById('ac-'+mid);
  if(!inp){ toast('⚠ Error'); return; }
  var amt=parseFloat(inp.value);
  if(!amt||amt<=0){ toast('⚠ Enter valid amount'); return; }
  var old=D.today[mid]||0;
  D.today[mid]=amt;
  var m=D.members.find(function(x){ return x.id===mid; });
  if(m){ m.totalPaid=m.totalPaid-old+amt; D.mpay[mkey(m.chitId,1,mid)]=amt; }
  toast('✅ Collected '+R(amt)+' from '+(m?m.name:'member'));
  renderAgentView();
}

