// ── CHIT TYPES ──
function addChitType(){
  var n=document.getElementById('ct-name').value.trim();
  var v=parseFloat(document.getElementById('ct-val').value);
  var mo=parseInt(document.getElementById('ct-mo').value);
  var st=document.getElementById('ct-st').value;
  var en=document.getElementById('ct-en').value;
  var sts=document.getElementById('ct-sts').value;
  if(!n||!v||!mo){ toast('⚠ Fill Chit Name, Value, Months'); return; }
  D.chitTypes.push({id:nid(),name:n,value:v,months:mo,start:st,end:en,status:sts});
  document.getElementById('ct-name').value='';
  document.getElementById('ct-val').value='';
  document.getElementById('ct-mo').value='';
  populateSels(); renderChitTypes();
  toast('✅ Chit type added!');
}

function renderChitTypes(){
  var el=document.getElementById('chittype-list'); if(!el) return;
  if(!D.chitTypes.length){ el.innerHTML='<div class="emp"><div class="emp-i">📋</div><div class="emp-t">No chit types yet.</div></div>'; return; }
  el.innerHTML=D.chitTypes.map(function(c){
    var mc=D.members.filter(function(m){ return m.chitId===c.id; }).length;
    var sc=c.status==='Running'?'bg':c.status==='Completed'?'bgy':'bgo';
    return '<div class="ci"><div class="ci-h"><div class="ci-n">'+c.name+'</div><span class="b '+sc+'">'+c.status+'</span></div>'+
      '<div class="ci-m">'+R(c.value)+' &bull; '+c.months+' months &bull; '+c.start+' → '+c.end+'</div>'+
      '<div class="ci-s"><span class="ci-st">👥 '+mc+' members</span><span class="ci-st">💰 '+R(c.value/c.months)+'/mo</span></div>'+
      '<div class="pgw"><div class="pgb" style="width:'+Math.min(Math.round(mc/Math.max(c.months,1)*100),100)+'%"></div></div></div>';
  }).join('');
}

