<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Sri Ramakrishna Krupa — Chit Fund</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --red:#C8102E;--red2:#9E0C23;--redL:#FFE8EC;--redP:#FFF5F7;
  --gold:#B8860B;--goldL:#FDF3DC;
  --ink:#1A0505;--ink2:#5A1A1A;--ink3:#9A6060;
  --bg:#FFFAF8;--bg2:#F9F0EE;--bg3:#F0E0DC;
  --white:#fff;
  --green:#1E7E4A;--greenL:#E6F7EE;
  --blue:#1A4FAB;--blueL:#EAF0FF;
  --orange:#C8580A;--orangeL:#FFF0E6;
  --bdr:#E8D0CC;
  --sh:0 4px 20px rgba(200,16,46,.10);
  --sh2:0 2px 8px rgba(26,5,5,.07);
  --r:14px;--rs:8px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh;-webkit-tap-highlight-color:transparent;}
button{font-family:'DM Sans',sans-serif;cursor:pointer;}
input,select{font-family:'DM Sans',sans-serif;}

/* ── SPLASH ── */
#splash{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:linear-gradient(160deg,#fff5f7 0%,#fffaf8 60%,#f0f5ff 100%);padding:32px 20px;text-align:center;}
#splash.hidden{display:none;}
.sp-logo{width:160px;margin-bottom:18px;border-radius:8px;}
.sp-title{font-family:'Playfair Display',serif;font-size:20px;font-weight:800;color:var(--red);line-height:1.3;}
.sp-tel{font-size:14px;color:var(--ink2);margin-top:4px;font-weight:500;}
.sp-line{width:50px;height:3px;background:var(--gold);border-radius:2px;margin:20px auto;}
.sp-cards{display:flex;flex-direction:column;gap:14px;width:100%;max-width:360px;}
.sp-card{background:white;border-radius:18px;padding:20px 18px;display:flex;align-items:center;gap:16px;
  box-shadow:var(--sh);border:2px solid transparent;transition:.2s;text-align:left;}
.sp-card:hover,.sp-card:active{border-color:var(--red);transform:translateY(-2px);}
.sp-card.agent:hover,.sp-card.agent:active{border-color:var(--blue);}
.sp-icon{font-size:32px;width:52px;height:52px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sp-card:first-of-type .sp-icon{background:var(--redL);}
.sp-card.agent .sp-icon{background:var(--blueL);}
.sp-ct{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;}
.sp-cs{font-size:12px;color:var(--ink3);margin-top:3px;line-height:1.5;}
.sp-arr{margin-left:auto;font-size:22px;color:var(--ink3);}
.sp-note{margin-top:20px;font-size:11px;color:var(--ink3);}

/* ── SCREENS ── */
.screen{display:none;min-height:100vh;flex-direction:column;}
.screen.on{display:flex;}

/* ── HEADER ── */
.hdr{background:var(--red);padding:10px 14px;display:flex;align-items:center;gap:10px;
  position:sticky;top:0;z-index:300;box-shadow:0 2px 12px rgba(200,16,46,.3);}
.hdr-logo{height:34px;border-radius:4px;}
.hdr-text{flex:1;}
.hdr-title{font-family:'Playfair Display',serif;color:white;font-size:15px;font-weight:700;line-height:1.2;}
.hdr-sub{font-size:10px;color:rgba(255,255,255,.72);margin-top:1px;}
.hdr-back{background:rgba(255,255,255,.18);border:1.5px solid rgba(255,255,255,.3);
  border-radius:50px;padding:5px 12px;color:white;font-size:12px;font-weight:600;white-space:nowrap;}

/* ── BOTTOM NAV ── */
.bnav{position:fixed;bottom:0;left:0;right:0;background:white;border-top:1px solid var(--bdr);
  display:flex;z-index:200;box-shadow:0 -3px 12px rgba(26,5,5,.08);}
.bni{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:9px 4px 13px;border:none;background:none;color:var(--ink3);transition:.15s;}
.bni.on{color:var(--red);}
.bni .ico{font-size:20px;line-height:1;}
.bni .lbl{font-size:10px;font-weight:600;margin-top:3px;}
.bni .dot{width:4px;height:4px;border-radius:50%;background:transparent;margin-top:3px;transition:.15s;}
.bni.on .dot{background:var(--red);}

/* ── CONTENT ── */
.content{flex:1;overflow-y:auto;padding:14px;padding-bottom:76px;max-width:600px;margin:0 auto;width:100%;}

/* ── PANELS ── */
.panel{display:none;}
.panel.on{display:block;}

/* ── TABS ── */
.tabs{display:flex;gap:3px;background:var(--bg2);border-radius:10px;padding:4px;margin-bottom:14px;overflow-x:auto;}
.tabs::-webkit-scrollbar{display:none;}
.tbb{flex:1;min-width:fit-content;padding:7px 10px;border-radius:8px;border:none;background:none;
  font-size:11px;font-weight:600;color:var(--ink3);transition:.15s;white-space:nowrap;}
.tbb.on{background:white;color:var(--red);box-shadow:var(--sh2);}

/* ── CARDS ── */
.card{background:white;border-radius:var(--r);padding:16px;box-shadow:var(--sh2);border:1px solid var(--bdr);margin-bottom:14px;}
.ct{font-family:'Playfair Display',serif;font-size:15px;font-weight:700;margin-bottom:14px;color:var(--ink);}
.spill{display:inline-block;background:var(--red);color:white;font-size:11px;font-weight:700;
  padding:4px 12px;border-radius:50px;margin-bottom:12px;letter-spacing:.4px;}

/* ── FORMS ── */
.fg{margin-bottom:12px;}
.fg label{display:block;font-size:11px;font-weight:700;color:var(--ink2);margin-bottom:5px;
  text-transform:uppercase;letter-spacing:.5px;}
.fg input,.fg select{width:100%;padding:10px 12px;border-radius:var(--rs);border:1.5px solid var(--bdr);
  font-size:14px;background:var(--bg);color:var(--ink);outline:none;transition:.15s;
  -webkit-appearance:none;appearance:none;}
.fg input:focus,.fg select:focus{border-color:var(--red);}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.fr3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;}

/* ── BUTTONS ── */
.btn{border:none;border-radius:50px;font-weight:600;font-size:14px;padding:11px 22px;transition:.15s;}
.btn-r{background:var(--red);color:white;}
.btn-r:active{background:var(--red2);}
.btn-g{background:var(--green);color:white;}
.btn-gold{background:var(--gold);color:white;}
.btn-o{background:white;color:var(--red);border:1.5px solid var(--red);}
.btn-sm{padding:7px 14px;font-size:12px;}
.btn-w{width:100%;}

/* ── STATS ── */
.sr{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
.sr3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:14px;}
.sb{background:white;border-radius:var(--rs);padding:12px 10px;text-align:center;border:1px solid var(--bdr);box-shadow:var(--sh2);}
.sb.r{background:var(--redL);border-color:#F5C0C8;}
.sb.g{background:var(--greenL);border-color:#b8e8cc;}
.sb.go{background:var(--goldL);border-color:#f0d890;}
.sb.b{background:var(--blueL);border-color:#c0d4f5;}
.sv{font-family:'Playfair Display',serif;font-size:20px;font-weight:800;}
.sv.r{color:var(--red);}
.sv.g{color:var(--green);}
.sv.go{color:var(--gold);}
.sv.b{color:var(--blue);}
.sl{font-size:10px;font-weight:600;color:var(--ink3);margin-top:3px;text-transform:uppercase;letter-spacing:.4px;}

/* ── TABLE ── */
.tbl{width:100%;border-collapse:collapse;font-size:12px;}
.tbl th{text-align:left;padding:8px 8px;font-size:10px;font-weight:700;color:var(--ink2);
  text-transform:uppercase;letter-spacing:.5px;background:var(--bg2);border-bottom:2px solid var(--bdr);}
.tbl td{padding:9px 8px;border-bottom:1px solid var(--bg3);vertical-align:middle;}
.tbl tr:last-child td{border-bottom:none;}
.tbl tr:hover td{background:var(--redP);}

/* ── BADGES ── */
.b{display:inline-block;padding:3px 8px;border-radius:50px;font-size:10px;font-weight:700;}
.bg{background:var(--greenL);color:var(--green);}
.br{background:var(--redL);color:var(--red);}
.bgo{background:var(--goldL);color:var(--gold);}
.bb{background:var(--blueL);color:var(--blue);}
.bgy{background:#f0f0f0;color:#666;}
.bo{background:var(--orangeL);color:var(--orange);}

/* ── MEMBER CARDS (agent) ── */
.mc{background:white;border-radius:var(--r);padding:14px;border:1px solid var(--bdr);box-shadow:var(--sh2);margin-bottom:12px;}
.mc-hd{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
.mc-n{font-family:'Playfair Display',serif;font-size:14px;font-weight:700;}
.mc-p{font-size:11px;color:var(--ink3);margin-top:2px;}
.mc-g{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:10px;}
.mc-gi{text-align:center;background:var(--bg2);border-radius:var(--rs);padding:7px 4px;}
.mc-gl{font-size:9px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.3px;}
.mc-gv{font-size:13px;font-weight:700;margin-top:2px;}
.mc-gv.r{color:var(--red);}
.mc-gv.g{color:var(--green);}
.mc-gv.o{color:var(--orange);}
.lbanner{background:var(--redL);border:1px solid #F5C0C8;border-radius:var(--rs);
  padding:7px 11px;font-size:11px;font-weight:600;color:var(--red);margin-bottom:8px;display:flex;align-items:center;gap:5px;}
.libanner{background:var(--goldL);border:1px solid #f0d890;border-radius:var(--rs);
  padding:7px 11px;font-size:11px;font-weight:600;color:var(--gold);margin-bottom:8px;display:flex;align-items:center;gap:5px;}
.ibanner{background:var(--orangeL);border:1px solid #f5c898;border-radius:var(--rs);
  padding:7px 11px;font-size:11px;font-weight:600;color:var(--orange);margin-bottom:8px;display:flex;align-items:center;gap:5px;}
.cr{display:flex;gap:8px;align-items:flex-end;}
.cr .fg{flex:1;margin:0;}

/* ── CHIT ITEM ── */
.ci{background:white;border-radius:var(--r);padding:14px;border:1px solid var(--bdr);margin-bottom:10px;box-shadow:var(--sh2);}
.ci-h{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.ci-n{font-family:'Playfair Display',serif;font-size:14px;font-weight:700;}
.ci-m{font-size:11px;color:var(--ink3);margin-bottom:8px;}
.ci-s{display:flex;gap:8px;flex-wrap:wrap;}
.ci-st{font-size:10px;background:var(--bg2);padding:3px 9px;border-radius:50px;font-weight:600;}
.pgw{background:var(--bg3);border-radius:50px;height:5px;margin-top:8px;}
.pgb{height:5px;border-radius:50px;background:var(--red);}

/* ── AGENT LOGIN ── */
.alw{max-width:380px;margin:50px auto 0;padding:20px;}
.alc{background:white;border-radius:22px;padding:32px 24px;box-shadow:var(--sh);text-align:center;}
.al-ico{font-size:48px;margin-bottom:12px;}
.al-t{font-family:'Playfair Display',serif;font-size:19px;font-weight:800;margin-bottom:4px;}
.al-s{color:var(--ink3);font-size:12px;margin-bottom:20px;}

/* ── AGENT WELCOME BAR ── */
.awbar{background:var(--red);border-radius:var(--r);padding:14px 16px;margin-bottom:14px;}
.aw-n{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;color:white;}
.aw-s{font-size:11px;color:rgba(255,255,255,.72);margin-top:2px;}
.aw-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:12px;}
.aw-st{background:rgba(255,255,255,.15);border-radius:10px;padding:10px;text-align:center;}
.aw-sv{font-family:'Playfair Display',serif;font-size:18px;font-weight:800;color:white;}
.aw-sl{font-size:10px;color:rgba(255,255,255,.7);margin-top:2px;}

/* ── SEARCH ── */
.sbar{display:flex;align-items:center;background:white;border:1.5px solid var(--bdr);
  border-radius:50px;padding:8px 14px;gap:8px;margin-bottom:12px;}
.sbar input{border:none;outline:none;font-size:13px;flex:1;background:transparent;}

/* ── EMPTY ── */
.emp{text-align:center;padding:30px 16px;color:var(--ink3);}
.emp-i{font-size:36px;margin-bottom:8px;}
.emp-t{font-size:13px;}

/* ── SLAB ROW ── */
.slr{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--bg3);font-size:12px;}
.slr:last-child{border:none;}

/* ── TOAST ── */
.toast{position:fixed;bottom:82px;left:50%;transform:translateX(-50%);
  background:var(--ink);color:white;padding:9px 20px;border-radius:50px;
  font-size:12px;font-weight:600;z-index:999;opacity:0;transition:opacity .3s;
  pointer-events:none;white-space:nowrap;max-width:88vw;text-align:center;}
.toast.show{opacity:1;}

/* ── DIVIDER ── */
.dv{height:1px;background:var(--bg3);margin:10px 0;}

@media(min-width:480px){.fr{grid-template-columns:1fr 1fr;}.fr3{grid-template-columns:1fr 1fr 1fr;}}
</style>
</head>
<body>

<!-- ══════════════ SPLASH ══════════════ -->
<div id="splash">
  <img id="sp-logo" class="sp-logo" src="" alt="Sri Ramakrishna Krupa">
  <div class="sp-title">Sri Ramakrishna Krupa</div>
  <div class="sp-tel">శ్రీ రామకృష్ణ కృప — Chit Fund</div>
  <div class="sp-line"></div>
  <div class="sp-cards">
    <div class="sp-card" onclick="openOwner()">
      <div class="sp-icon">🏦</div>
      <div>
        <div class="sp-ct">Owner Dashboard</div>
        <div class="sp-cs">Masters · Chit Mgmt · Statements · Loans</div>
      </div>
      <div class="sp-arr">›</div>
    </div>
    <div class="sp-card agent" onclick="openAgent()">
      <div class="sp-icon">🧾</div>
      <div>
        <div class="sp-ct">Agent / Field View</div>
        <div class="sp-cs">Collect · Loans · Lifted members</div>
      </div>
      <div class="sp-arr">›</div>
    </div>
  </div>
  <div class="sp-note">⚡ Demo — data resets on refresh</div>
</div>

<!-- ══════════════ OWNER ══════════════ -->
<div id="owner" class="screen">
  <div class="hdr">
    <img id="o-logo" class="hdr-logo" src="" alt="logo">
    <div class="hdr-text">
      <div class="hdr-title">Sri Ramakrishna Krupa</div>
      <div class="hdr-sub">Owner Dashboard</div>
    </div>
    <button class="hdr-back" onclick="goHome()">← Home</button>
  </div>

  <div class="content">

    <!-- MASTERS -->
    <div id="p-masters" class="panel on">
      <div class="tabs" id="mt-tabs">
        <button class="tbb on" onclick="mTab('mt-chittype',this)">📋 Chit Types</button>
        <button class="tbb" onclick="mTab('mt-agents',this)">🤝 Agents</button>
        <button class="tbb" onclick="mTab('mt-members',this)">👥 Members</button>
        <button class="tbb" onclick="mTab('mt-slabs',this)">📊 Slabs</button>
      </div>

      <!-- CHIT TYPES -->
      <div id="mt-chittype" class="panel on">
        <div class="spill">📋 Chit Types</div>
        <div class="card">
          <div class="ct">Add New Chit Type</div>
          <div class="fr"><div class="fg"><label>Chit Name</label><input id="ct-name" placeholder="e.g. Gold Chit 2025"></div>
          <div class="fg"><label>Total Value (₹)</label><input id="ct-val" type="number" placeholder="100000"></div></div>
          <div class="fr3"><div class="fg"><label>Months</label><input id="ct-mo" type="number" placeholder="20"></div>
          <div class="fg"><label>Start Date</label><input id="ct-st" type="date"></div>
          <div class="fg"><label>End Date</label><input id="ct-en" type="date"></div></div>
          <div class="fg"><label>Status</label>
            <select id="ct-sts"><option>Running</option><option>Completed</option><option>Upcoming</option></select></div>
          <button class="btn btn-r btn-w" onclick="addChitType()">+ Add Chit Type</button>
        </div>
        <div id="chittype-list"></div>
      </div>

      <!-- AGENTS -->
      <div id="mt-agents" class="panel">
        <div class="spill">🤝 Agents & References</div>
        <div class="card">
          <div class="ct">Add Agent / Reference</div>
          <div class="fr"><div class="fg"><label>Name</label><input id="ag-n" placeholder="Full name"></div>
          <div class="fg"><label>Phone</label><input id="ag-ph" placeholder="10-digit"></div></div>
          <div class="fr"><div class="fg"><label>Role</label>
            <select id="ag-rl"><option>Agent</option><option>Reference</option><option>Agent+Reference</option></select></div>
          <div class="fg"><label>Commission %</label><input id="ag-cm" type="number" placeholder="2"></div></div>
          <button class="btn btn-r btn-w" onclick="addAgent()">+ Add</button>
        </div>
        <div id="agents-list"></div>
      </div>

      <!-- MEMBERS -->
      <div id="mt-members" class="panel">
        <div class="spill">👥 Chit Members</div>
        <div class="card">
          <div class="ct">Add Chit Member</div>
          <div class="fr"><div class="fg"><label>Member Name</label><input id="mb-n" placeholder="Full name"></div>
          <div class="fg"><label>Phone (ID)</label><input id="mb-ph" placeholder="10-digit phone"></div></div>
          <div class="fr"><div class="fg"><label>Assign to Chit</label><select id="mb-ch"></select></div>
          <div class="fg"><label>Monthly Due (₹)</label><input id="mb-du" type="number" placeholder="5000"></div></div>
          <div class="fr"><div class="fg"><label>Assign Agent</label><select id="mb-ag"></select></div>
          <div class="fg"><label>Reference</label><select id="mb-rf"></select></div></div>
          <button class="btn btn-r btn-w" onclick="addMember()">+ Add Member</button>
        </div>
        <div class="sbar"><span>🔍</span><input id="mb-srch" placeholder="Search name or phone…" oninput="renderMembers()"></div>
        <div id="members-list"></div>
      </div>

      <!-- SLABS -->
      <div id="mt-slabs" class="panel">
        <div class="spill">📊 Slabs (Commission / Dividend)</div>
        <div class="card">
          <div class="ct">Define Slab</div>
          <div class="fr"><div class="fg"><label>Chit Type</label><select id="sl-ch"></select></div>
          <div class="fg"><label>Month No.</label><input id="sl-mo" type="number" placeholder="1"></div></div>
          <div class="fr"><div class="fg"><label>Dividend (₹)</label><input id="sl-dv" type="number" placeholder="5000"></div>
          <div class="fg"><label>Commission (₹)</label><input id="sl-cm" type="number" placeholder="1000"></div></div>
          <button class="btn btn-r btn-w" onclick="addSlab()">+ Save Slab</button>
        </div>
        <div id="slabs-list"></div>
      </div>
    </div>

    <!-- CHIT MANAGEMENT -->
    <div id="p-chitman" class="panel">
      <div class="tabs">
        <button class="tbb on" onclick="cmTab('cm-acc',this)">📁 Accounts</button>
        <button class="tbb" onclick="cmTab('cm-slip',this)">🗒 Month Slip</button>
        <button class="tbb" onclick="cmTab('cm-col',this)">💰 Collection</button>
        <button class="tbb" onclick="cmTab('cm-auc',this)">🏆 Auction</button>
      </div>

      <!-- ACCOUNTS -->
      <div id="cm-acc" class="panel on">
        <div class="spill">📁 Chit Accounts</div>
        <div id="cm-acc-body"></div>
      </div>

      <!-- MONTH SLIP -->
      <div id="cm-slip" class="panel">
        <div class="spill">🗒 Month Slip Update</div>
        <div class="card">
          <div class="fr"><div class="fg"><label>Select Chit</label><select id="ms-ch" onchange="renderSlip()"></select></div>
          <div class="fg"><label>Month No.</label><input id="ms-mo" type="number" value="1" min="1" onchange="renderSlip()"></div></div>
        </div>
        <div id="slip-body"></div>
      </div>

      <!-- COLLECTION -->
      <div id="cm-col" class="panel">
        <div class="spill">💰 Monthly Collection</div>
        <div class="card">
          <div class="fr"><div class="fg"><label>Select Chit</label><select id="co-ch" onchange="renderCollection()"></select></div>
          <div class="fg"><label>Month No.</label><input id="co-mo" type="number" value="1" min="1" onchange="renderCollection()"></div></div>
        </div>
        <div id="col-sum"></div>
        <div id="col-tbl"></div>
      </div>

      <!-- AUCTION -->
      <div id="cm-auc" class="panel">
        <div class="spill">🏆 Chit Auction (Lifted)</div>
        <div class="card">
          <div class="ct">Record Auction</div>
          <div class="fr"><div class="fg"><label>Select Chit</label><select id="au-ch"></select></div>
          <div class="fg"><label>Month No.</label><input id="au-mo" type="number" placeholder="1"></div></div>
          <div class="fr"><div class="fg"><label>Member Phone</label><input id="au-ph" placeholder="Winner's phone"></div>
          <div class="fg"><label>Bid Amount (₹)</label><input id="au-bd" type="number" placeholder="90000"></div></div>
          <button class="btn btn-gold btn-w" onclick="recordAuction()">🏆 Record Lift</button>
        </div>
        <div id="auc-list"></div>
      </div>
    </div>

    <!-- STATEMENT -->
    <div id="p-stmt" class="panel">
      <div class="tabs">
        <button class="tbb on" onclick="stTab('st-mbr',this)">👤 Member</button>
        <button class="tbb" onclick="stTab('st-agt',this)">🤝 Agent</button>
